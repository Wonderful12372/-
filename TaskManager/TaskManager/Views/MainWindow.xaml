<Window x:Class="TaskManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TaskManager.Models"
        Title="📋 Менеджер задач" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox Width="250" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,10,0"
                     ToolTip="Поиск по названию или описанию">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Padding" Value="5,3"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </TextBox.Style>
            </TextBox>
            
            <ComboBox Width="130" 
                      SelectedItem="{Binding FilterState}"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding States}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            
            <ComboBox Width="130" 
                      SelectedItem="{Binding FilterPriority}"
                      ItemsSource="{Binding Priorities}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            
            <Separator Width="20" Background="Transparent"/>
            
            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="100" SelectedItem="{Binding SortBy}">
                <ComboBoxItem Content="Дата"/>
                <ComboBoxItem Content="Название"/>
            </ComboBox>
        </StackPanel>
        <DataGrid Grid.Row="1" 
                  x:Name="TasksDataGrid"
                  ItemsSource="{Binding TasksView}"
                  SelectedItem="{Binding SelectedTask}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  RowHeight="35"
                  GridLinesVisibility="Horizontal"
                  Background="White"
                  BorderBrush="#E0E0E0">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="📝 Название" 
                                    Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                    Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="Validation.HasError" Value="True">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="ToolTip" Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridComboBoxColumn Header="🔄 Статус" 
                                        SelectedItemBinding="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                                        Width="120">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.States, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.States, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>
                <DataGridComboBoxColumn Header="⚡ Приоритет" 
                                        SelectedItemBinding="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                                        Width="100">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.Priorities, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.Priorities, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>
                
                <DataGridTextColumn Header="📅 Дата" 
                                    Binding="{Binding CreatedDate, StringFormat='dd.MM.yyyy HH:mm'}"
                                    Width="150"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
            
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding State}" Value="Выполнена">
                            <Setter Property="Background" Value="#E8F5E9"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding State}" Value="Отменена">
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="➕ Добавить" 
                    Command="{Binding AddCommand}"
                    Width="110" Height="35" Margin="0,0,10,0"
                    Background="#4CAF50" Foreground="White" FontWeight="Medium"/>
            
            <Button Content="🗑️ Удалить" 
                    Command="{Binding DeleteCommand}"
                    Width="110" Height="35" Margin="0,0,10,0"
                    Background="#F44336" Foreground="White" FontWeight="Medium"/>
            
            <Separator Width="20" Background="Transparent"/>
            
            <Button Content="💾 Сохранить" 
                    Command="{Binding SaveCommand}"
                    Width="110" Height="35" Margin="0,0,10,0"
                    Background="#2196F3" Foreground="White" FontWeight="Medium"/>
            
            <Button Content="📥 Загрузить" 
                    Command="{Binding LoadCommand}"
                    Width="110" Height="35"
                    Background="#9E9E9E" Foreground="White" FontWeight="Medium"/>
        </StackPanel>
    </Grid>
</Window>