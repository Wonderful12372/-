<Window x:Class="WeatherApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Погода WPF" Height="550" Width="650"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource TextForeground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Введите название города:" 
                       FontSize="14" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding CityName, UpdateSourceTrigger=PropertyChanged}" 
                         Width="300" Margin="0,0,10,0"/>
                <Button Content="🔍 Поиск" 
                        Command="{Binding SearchWeatherCommand}"
                        Padding="16,8"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="🌓 Тема" 
                        Command="{Binding ChangeThemeCommand}"
                        Padding="16,8"
                        Margin="10,0,0,0"
                        Background="{DynamicResource SecondaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
        <TextBlock Grid.Row="1" 
                   Text="{Binding ErrorMessage}" 
                   Foreground="Crimson" 
                   FontSize="13" 
                   TextWrapping="Wrap" 
                   Margin="0,0,0,15"/>
        <Border Grid.Row="2" 
                Padding="20" 
                Background="{DynamicResource CardBackground}" 
                CornerRadius="8"
                Margin="0,0,0,15">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentWeather}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            
            <StackPanel HorizontalAlignment="Center">
                <Image Source="{Binding IconUrl}" Width="100" Height="100" Margin="0,0,0,15"/>
                <TextBlock Text="{Binding CurrentWeather.CityName}" 
                           FontSize="28" FontWeight="Bold" 
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding CurrentWeather.Weather[0].Description}" 
                           FontSize="16" 
                           Foreground="Gray"
                           TextAlignment="Center"
                           Margin="0,5,0,15"/>
                <TextBlock Text="{Binding CurrentWeather.Main.Temperature, StringFormat='{}{0:F1}°C'}" 
                           FontSize="48" FontWeight="Bold" 
                           TextAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,15"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentWeather.Main.Humidity, StringFormat='💧 Влажность: {0}%'}" 
                               FontSize="14" Margin="0,0,20,0"/>
                    <TextBlock Text="{Binding CurrentWeather.Wind.Speed, StringFormat='💨 Ветер: {0} м/с'}" 
                               FontSize="14"/>
                </StackPanel>
                <TextBlock Text="{Binding CurrentWeather.Main.Pressure, StringFormat='🔽 Давление: {0} гПа'}" 
                           FontSize="14" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="3">
            <TextBlock Text="📋 История запросов:" 
                       FontSize="14" FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <ListBox ItemsSource="{Binding History}" 
                     SelectedItem="{Binding CityName, Mode=TwoWay}"
                     Background="Transparent" 
                     BorderThickness="0"
                     MaxHeight="100">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" 
                                   Margin="0,3" 
                                   Cursor="Hand"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>